# Your Convex deployment's cloud URL (the same value as EXPO_PUBLIC_CONVEX_URL
# in the host app), e.g. https://cheetful-basilisk-511.convex.cloud
VITE_CONVEX_URL=

# App slug registered with Sprout (see convex/sproutSetup.ts in the host app).
VITE_SPROUT_SLUG=

# Shared secret checked by the host's convex/sprout.ts query wrappers.
# Intentionadoelly exposed to the browser bundle (VITE_-prefixed) -- this app is
# a localhost-only tool, so there's no one else to hide the
# key from. Do not serve this build beyond localhost.
VITE_SPROUT_DASHBOARD_KEY=<a random secret, e.g. `openssl rand -hex 16`>
